<views:SubformWindow xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:views="using:PKHeX.Avalonia.Views"
                    xmlns:vm="using:PKHeX.Avalonia.ViewModels.Subforms"
                    x:Class="PKHeX.Avalonia.Views.Subforms.DLC5View"
                    x:DataType="vm:DLC5ViewModel"
                    Title="Gen 5 DLC Editor"
                    Width="620" Height="600"
                    MinWidth="500" MinHeight="450"
                    FontFamily="Microsoft Sans Serif,Geneva,Helvetica,Arial,sans-serif"
                    FontSize="11"
                    WindowStartupLocation="CenterOwner"
                    CanResize="True">

    <DockPanel Margin="8">
        <!-- Bottom buttons + status -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="10" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="OK" Click="OnOkClick" MinWidth="75" Padding="8,4" />
                <Button Content="Cancel" Click="OnCancelClick" MinWidth="75" Padding="8,4" />
            </StackPanel>
        </StackPanel>

        <TabControl>
            <!-- C-Gear -->
            <TabItem Header="C-Gear">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="C-Gear Skin" FontWeight="SemiBold" FontSize="11" />
                    <TextBlock Text="{Binding CGearStatus}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import C-Gear" Click="OnImportCGearClick" MinWidth="90" Padding="8,4" />
                        <Button Content="Export C-Gear" Click="OnExportCGearClick" MinWidth="90" Padding="8,4"
                                IsEnabled="{Binding HasCGear}" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Battle Videos -->
            <TabItem Header="Battle Videos">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Battle Videos" FontWeight="SemiBold" FontSize="11" />
                    <ListBox ItemsSource="{Binding BattleVideos}" SelectedIndex="{Binding SelectedBattleVideoIndex}" MaxHeight="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:BattleVideo5Entry">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportBattleVideoClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportBattleVideoClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- PWT (B2W2 only) -->
            <TabItem Header="PWT" IsVisible="{Binding ShowPWT}">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Pokemon World Tournament" FontWeight="SemiBold" FontSize="11" />
                    <ListBox ItemsSource="{Binding PWTEntries}" SelectedIndex="{Binding SelectedPWTIndex}" MaxHeight="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PWT5Entry">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportPWTClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportPWTClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Pokestar (B2W2 only) -->
            <TabItem Header="Pokestar" IsVisible="{Binding ShowPokestar}">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Pokestar Studios" FontWeight="SemiBold" FontSize="11" />
                    <ListBox ItemsSource="{Binding PokestarMovies}" SelectedIndex="{Binding SelectedPokestarIndex}" MaxHeight="250">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:Pokestar5Entry">
                                <TextBlock Text="{Binding Label}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportPokestarClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportPokestarClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Musical -->
            <TabItem Header="Musical">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Musical Show" FontWeight="SemiBold" FontSize="11" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Musical Name:" VerticalAlignment="Center" />
                        <TextBox Text="{Binding MusicalName}" Width="200" Height="25" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportMusicalClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportMusicalClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Memory Link -->
            <TabItem Header="Memory Link">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Memory Link Data" FontWeight="SemiBold" FontSize="11" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Link 1:" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <Button Content="Import" Click="OnImportLink1Click" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportLink1Click" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Link 2:" VerticalAlignment="Center" FontWeight="SemiBold" />
                        <Button Content="Import" Click="OnImportLink2Click" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportLink2Click" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Pokedex Skin -->
            <TabItem Header="Dex Skin">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Pokedex Skin" FontWeight="SemiBold" FontSize="11" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportPokedexSkinClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportPokedexSkinClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Battle Test -->
            <TabItem Header="Battle Test">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock Text="Battle Test" FontWeight="SemiBold" FontSize="11" />
                    <TextBlock Text="Needs research. Import/export raw data only." Foreground="Orange" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Import" Click="OnImportBattleTestClick" MinWidth="75" Padding="8,4" />
                        <Button Content="Export" Click="OnExportBattleTestClick" MinWidth="75" Padding="8,4" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>

</views:SubformWindow>
