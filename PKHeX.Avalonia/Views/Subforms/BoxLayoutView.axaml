<views:SubformWindow xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:views="using:PKHeX.Avalonia.Views"
                     xmlns:vm="using:PKHeX.Avalonia.ViewModels.Subforms"
                     x:Class="PKHeX.Avalonia.Views.Subforms.BoxLayoutView"
                     x:DataType="vm:BoxLayoutViewModel"
                     Title="Box Layout Editor"
                     Width="450" Height="450"
                     MinWidth="350" MinHeight="300"
                     WindowStartupLocation="CenterOwner"
                     CanResize="True">

    <DockPanel Margin="8">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="OK" Click="OnOkClick" Width="80" />
            <Button Content="Cancel" Click="OnCancelClick" Width="80" />
        </StackPanel>

        <!-- Box list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Boxes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BoxDetailModel">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,4" VerticalAlignment="Center">
                            <!-- Box number label -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Index, StringFormat='Box {0}:'}"
                                       VerticalAlignment="Center"
                                       Width="60"
                                       Margin="0,0,8,0" />

                            <!-- Name TextBox -->
                            <TextBox Grid.Column="1"
                                     Text="{Binding Name}"
                                     Watermark="Box name"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0" />

                            <!-- Wallpaper label -->
                            <TextBlock Grid.Column="2"
                                       Text="WP:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />

                            <!-- Wallpaper NumericUpDown -->
                            <NumericUpDown Grid.Column="3"
                                           Value="{Binding Wallpaper}"
                                           Minimum="0"
                                           Maximum="255"
                                           Width="80"
                                           VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

</views:SubformWindow>
